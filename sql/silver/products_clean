CREATE TABLE silver.products_clean AS
SELECT
    product_id,
    LOWER(TRIM(product_category_name)) AS product_category_name,
    product_name_length,
    product_description_length,
    product_photos_qty,
    product_weight_g,
    product_length_cm,
    product_height_cm,
    product_width_cm
FROM bronze.products_raw
WHERE product_id IS NOT NULL;