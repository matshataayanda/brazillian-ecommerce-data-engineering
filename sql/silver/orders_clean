CREATE TABLE silver.orders_clean AS
SELECT DISTINCT
    order_id,
    customer_id,
    LOWER(order_status) AS order_status,

    CAST(NULLIF(TRIM(order_purchase_timestamp), '') AS TIMESTAMP) AS purchase_ts,
    CAST(NULLIF(TRIM(order_approved_at), '') AS TIMESTAMP) AS approved_ts,
    CAST(NULLIF(TRIM(order_delivered_carrier_date), '') AS TIMESTAMP) AS carrier_ts,
    CAST(NULLIF(TRIM(order_delivered_customer_date), '') AS TIMESTAMP) AS delivered_ts,
    CAST(NULLIF(TRIM(order_estimated_delivery_date), '') AS TIMESTAMP) AS estimated_ts

FROM bronze.orders_raw
WHERE order_id IS NOT NULL;